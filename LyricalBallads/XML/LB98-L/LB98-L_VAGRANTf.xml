   <text>
      <front>
         <pb n="68"/>
         <epigraph>
            <q>
               <l>Time flies—it is his melancholy task</l>
               <l>To bring and bear away illusive
                hopes</l>
               <l>And reproduce the troubles hi destroy’s.</l>
               <l>But while his
                blindness thus is occupied</l>
               <l>Discerning Mortal do Thou serve the will</l>
               <l>Of
                Time’s eternal Master and that peace,</l>
               <l>Which the World wants, shall be
                for Thee confirmed</l>
            </q>
         </epigraph>
         <p rend="signature">Excursion—<lb/>
            <name>Wm Wordsworth</name>
            <lb/>
            <date>July-5th
              1834</date>
         </p>
      </front>
