   <text>
      <body>
         <pb/>
         <milestone n="52" unit="page"/>
         <lb/>
         <lb/>
         <lb/>
         <lg n="1">
            <l n="1">She dwelt among th’ untrodden ways</l>
            <l n="2" rend="indent"> Beside the springs of Dove,</l>
            <l n="3">A Maid whom there were none to praise,</l>
            <l n="4" rend="indent"> And very few to love.</l>
         </lg>
         <lg n="2">
            <l n="5">A Violet by a mossy stone</l>
            <l n="6" rend="indent"> Half-hidden from the eye!</l>
            <l n="7">—Fair as a star, when only one</l>
            <l n="8" rend="indent"> Is shining in the sky.</l>
         </lg>
         <lg n="3">
            <l n="9">She lived unknown, and few could know </l>
            <l rend="indent" n="10"> When Lucy ceased to be;</l>
            <l n="11">But she is in her Grave, and oh!</l>
            <l rend="indent" n="12"> The difference to me.</l>
         </lg>
      </body>
