      <body>
         <pb/>
         <milestone n="53" unit="page"/>
         <lb/>
         <lb/>
         <lb/>
         <lg n="1">
            <l n="1">A slumber did my spirit seal;</l>
            <l rend="indent" n="2"> I had no human fears:</l>
            <l n="3">She seemed a thing that could not feel</l>
            <l rend="indent" n="4"> The touch of earthly years.</l>
         </lg>
         <lg n="2">
            <l n="5">No motion has she now, no force;</l>
            <l rend="indent" n="6"> She neither hears nor sees,</l>
            <l n="7">Rolled round in earth’s diurnal course</l>
            <l rend="indent" n="8"> With rocks and stones and trees!</l>
         </lg>
      </body>
