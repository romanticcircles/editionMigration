     lang IDREF #IMPLIED 
     rend CDATA #IMPLIED 
     status (free | unknown | restricted) #IMPLIED 
     TEIform CDATA "availability" >

<!--  5.2.5:  The series statement                             -->

<!ELEMENT seriesStmt - O ((title, (idno | respStmt)*) | (p)+)>

<!ATTLIST seriesStmt 
